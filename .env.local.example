# 数据库配置
DATABASE_URL="file:./dev.db"

# AI服务配置
AI_PROVIDER=deepseek

# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat

# 通义千问
TONGYI_API_KEY=your_tongyi_api_key_here
TONGYI_MODEL=qwen-max

# 智谱AI
ZHIPU_API_KEY=your_zhipu_api_key_here
ZHIPU_MODEL=glm-4-plus

# 月之暗面Kimi
KIMI_API_KEY=your_kimi_api_key_here
KIMI_MODEL=moonshot-v1-128k

# 零一万物
YI_API_KEY=your_yi_api_key_here
YI_MODEL=yi-large

# 讯飞星火
SPARK_API_KEY=your_spark_api_key_here
SPARK_MODEL=generalv3.5

# 腾讯混元
HUNYUAN_API_KEY=your_hunyuan_api_key_here
HUNYUAN_MODEL=hunyuan-pro

# 字节豆包
DOUBAO_API_KEY=your_doubao_api_key_here
DOUBAO_MODEL=doubao-pro-4k

# MiniMax
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_MODEL=abab6.5-chat

# 备用AI厂商（主厂商失败时自动切换）
AI_FALLBACK_PROVIDERS=tongyi,zhipu,kimi

# 飞书配置
FEISHU_APP_ID=your_feishu_app_id_here
FEISHU_APP_SECRET=your_feishu_app_secret_here
FEISHU_VERIFICATION_TOKEN=your_feishu_verification_token_here
FEISHU_ENCRYPT_KEY=your_feishu_encrypt_key_here

# 应用配置
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 管理员配置（逗号分隔多个邮箱）
ADMIN_EMAILS=admin@example.com

# 支付回调IP白名单（逗号分隔，留空则不限制）
PAYMENT_CALLBACK_IPS=

# SMS短信服务配置
# 可选值: aliyun / tencent / netease / mock (开发测试用)
SMS_PROVIDER=mock

# 阿里云短信
ALIYUN_ACCESS_KEY_ID=your_aliyun_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_aliyun_access_key_secret
ALIYUN_SIGN_NAME=your_sign_name
ALIYUN_TEMPLATE_CODE=your_template_code

# 腾讯云短信
TENCENT_SECRET_ID=your_tencent_secret_id
TENCENT_SECRET_KEY=your_tencent_secret_key
TENCENT_APP_ID=your_tencent_app_id
TENCENT_TEMPLATE_ID=your_tencent_template_id
TENCENT_SIGN_NAME=your_tencent_sign_name

# 网易云信
NETEASE_APP_KEY=your_netease_app_key
NETEASE_APP_SECRET=your_netease_app_secret
NETEASE_TEMPLATE_ID=your_netease_template_id

# 支付服务配置
# 可选值: wechat / alipay / mock (开发测试用)
PAYMENT_PROVIDER=mock

# 微信支付
WECHAT_MCH_ID=your_wechat_mch_id
WECHAT_API_KEY=your_wechat_api_key
WECHAT_APP_ID=your_wechat_app_id
WECHAT_CERT_PATH=./certs/wechat_cert.pem
WECHAT_KEY_PATH=./certs/wechat_key.pem

# 支付宝
ALIPAY_APP_ID=your_alipay_app_id
ALIPAY_PRIVATE_KEY=your_alipay_private_key
ALIPAY_PUBLIC_KEY=your_alipay_public_key
ALIPAY_CERT_PATH=./certs/alipay_cert.pem
ALIPAY_ROOT_CERT_PATH=./certs/alipay_root_cert.pem
