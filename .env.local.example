# AI服务配置
AI_PROVIDER=deepseek

# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat

# 通义千问
TONGYI_API_KEY=your_tongyi_api_key_here
TONGYI_MODEL=qwen-max

# 智谱AI
ZHIPU_API_KEY=your_zhipu_api_key_here
ZHIPU_MODEL=glm-4-plus

# 月之暗面Kimi
KIMI_API_KEY=your_kimi_api_key_here
KIMI_MODEL=moonshot-v1-128k

# 零一万物
YI_API_KEY=your_yi_api_key_here
YI_MODEL=yi-large

# 讯飞星火
SPARK_API_KEY=your_spark_api_key_here
SPARK_MODEL=generalv3.5

# 腾讯混元
HUNYUAN_API_KEY=your_hunyuan_api_key_here
HUNYUAN_MODEL=hunyuan-pro

# 字节豆包
DOUBAO_API_KEY=your_doubao_api_key_here
DOUBAO_MODEL=doubao-pro-4k

# MiniMax
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_MODEL=abab6.5-chat

# 备用AI厂商（主厂商失败时自动切换）
AI_FALLBACK_PROVIDERS=tongyi,zhipu,kimi
