# 数据库配置
DATABASE_URL="postgresql://postgres:your_password@your_host:5432/postgres"

# AI服务配置 - 默认使用豆包（最便宜）
AI_PROVIDER=doubao

# 字节豆包（推荐，最便宜）
DOUBAO_API_KEY=your_doubao_api_key_here
DOUBAO_MODEL=your_doubao_model_here

# DeepSeek（备用）
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat

# 通义千问
TONGYI_API_KEY=your_tongyi_api_key_here
TONGYI_MODEL=qwen-max

# 智谱AI
ZHIPU_API_KEY=your_zhipu_api_key_here
ZHIPU_MODEL=glm-4-plus

# 月之暗面Kimi
KIMI_API_KEY=your_kimi_api_key_here
KIMI_MODEL=moonshot-v1-128k

# 备用AI厂商（主厂商失败时自动切换）
AI_FALLBACK_PROVIDERS=deepseek

# 企业微信机器人配置（用于支付通知）
WECHAT_BOT_ID=your_wechat_bot_id_here
WECHAT_BOT_SECRET=your_wechat_bot_secret_here
WECHAT_ADMIN_USERID=your_admin_userid_here

# 飞书开放平台配置
FEISHU_APP_ID=your_feishu_app_id_here
FEISHU_APP_SECRET=your_feishu_app_secret_here

# JWT Secret for backend authentication
JWT_SECRET=your_random_jwt_secret_here_generate_with_python_secrets_token_hex_32

# 管理员配置（逗号分隔多个邮箱）
ADMIN_EMAILS=admin@example.com

# 应用配置
NEXT_PUBLIC_APP_URL=http://localhost:3000
