generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String?
  password      String
  phone         String?
  wechatOpenId  String?        @unique
  avatar        String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  assessments   Assessment[]
  sessions      Session[]
  knowledgeItems KnowledgeItem[]
  projects      Project[]
}

model Session {
  id            String   @id @default(cuid())
  userId        String
  token         String   @unique
  expiresAt     DateTime
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id])
}

model Assessment {
  id                    String   @id @default(cuid())
  userId                String
  projectName           String
  projectCode           String?
  budget                Float    @default(0)
  riskLevel             String   @default("medium")
  recommendation        String   @default("caution")
  fileName              String
  fileContent           String?
  aiResult              String   @default("{}")
  basicInfo             String   @default("{}")
  risks                 String   @default("[]")
  tasks                 String   @default("[]")
  scoringRules          String   @default("{}")
  qualificationReqs     String   @default("[]")
  technicalResponse     String   @default("[]")
  bidDeadline           DateTime?
  bidOpeningTime        DateTime?
  queryDeadline         DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id])
}

model KnowledgeItem {
  id            String   @id @default(cuid())
  userId        String
  title         String
  category      String   @default("未分类")
  subcategory   String?
  content       String   @default("")
  tags          String   @default("[]")
  fileType      String   @default("text")
  fileName      String?
  fileUrl       String?
  source        String   @default("manual")
  sourceId      String?
  metadata      String   @default("{}")
  usageCount    Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id])
}

model Project {
  id            String   @id @default(cuid())
  userId        String
  name          String
  description   String?
  status        String   @default("active")
  members       String   @default("[]")
  tasks         String   @default("[]")
  metadata      String   @default("{}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id])
}
