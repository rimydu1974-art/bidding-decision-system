generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String         @id @default(cuid())
  email           String         @unique
  name            String?
  password        String
  phone           String?
  wechatOpenId    String?        @unique
  avatar          String?
  // 订阅相关
  plan            String         @default("free") // free/pro/enterprise
  planExpiresAt   DateTime?      // 订阅过期时间
  tempExpiresAt   DateTime?      // 单次购买临时权限过期时间
  // 额度相关
  aiQuotaUsed     Int            @default(0)  // 本月已用AI次数
  aiQuotaResetAt  DateTime       @default(now()) // 额度重置时间
  // 用户自备API
  userApiKey      String?        // 用户自己的DeepSeek API Key
  apiKeyVerified  Boolean        @default(false) // API Key是否验证通过
  // 统计
  totalAiCalls    Int            @default(0)  // 总AI调用次数
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  assessments     Assessment[]
  sessions        Session[]
  knowledgeItems  KnowledgeItem[]
  projects        Project[]
  orders          Order[]
}

model Session {
  id            String   @id @default(cuid())
  userId        String
  token         String   @unique
  expiresAt     DateTime
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id])
}

model Assessment {
  id                    String   @id @default(cuid())
  userId                String
  projectName           String
  projectCode           String?
  budget                Float    @default(0)
  riskLevel             String   @default("medium")
  recommendation        String   @default("caution")
  fileName              String
  fileContent           String?
  aiResult              String   @default("{}")
  basicInfo             String   @default("{}")
  risks                 String   @default("[]")
  tasks                 String   @default("[]")
  scoringRules          String   @default("{}")
  qualificationReqs     String   @default("[]")
  technicalResponse     String   @default("[]")
  bidDeadline           DateTime?
  bidOpeningTime        DateTime?
  queryDeadline         DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id])
}

model KnowledgeItem {
  id            String   @id @default(cuid())
  userId        String
  title         String
  category      String   @default("未分类")
  subcategory   String?
  content       String   @default("")
  tags          String   @default("[]")
  fileType      String   @default("text")
  fileName      String?
  fileUrl       String?
  source        String   @default("manual")
  sourceId      String?
  metadata      String   @default("{}")
  usageCount    Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id])
}

model Project {
  id            String   @id @default(cuid())
  userId        String
  name          String
  description   String?
  status        String   @default("active")
  members       String   @default("[]")
  tasks         String   @default("[]")
  metadata      String   @default("{}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id])
}

model PricingPlan {
  id            String   @id @default(cuid())
  name          String
  displayName   String
  price         Float
  period        String   @default("month")
  description   String?
  features      String   @default("[]")
  highlight     Boolean  @default(false)
  sortOrder     Int      @default(0)
  isActive      Boolean  @default(true)
  metadata      String   @default("{}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Order {
  id              String   @id @default(cuid())
  userId          String
  orderNo         String   @unique
  planName        String   // pro/enterprise/single
  amount          Float
  paymentMethod   String?  // alipay/wechat
  paymentStatus   String   @default("pending") // pending/paid/refunded
  paidAt          DateTime?
  expiresAt       DateTime // 权限过期时间
  metadata        String   @default("{}")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id])
}

model PasswordReset {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  @@index([email])
  @@index([token])
}
